lane :all do |params|
  env = (params[:env] != 'chat' && params[:env] != nil && params[:env] != '') ? params[:env] : 'chat'
  increase_version = params[:increase_version] == false ? false : true
  upload_to_testflight = params[:upload_to_testflight] == false ? false : true
  upload_to_pgyer = params[:upload_to_pgyer] == false ? false : true
  upload_to_huggingface = params[:upload_to_huggingface] == false ? false : true
  huggingface_repo_id = params[:huggingface_repo_id] || ENV['HF_DATASETS_ID']
  skip_git_reset = params[:skip_git_reset] == true ? true : false

  build_number = raw_increase_build_number()
  raw_change_analysis_options()
  dart_fix()
  raw_change_analysis_options()
  version_number = raw_get_version_number()
  if increase_version
    version_number = raw_increase_version_number()
  end
  if env == 'chat'
    git_commit(message: version_number.to_s + '(' + build_number.to_s + ')', path: '*')
    push_to_git_remote()
  end
  global_replace(env: env) # 替换环境变量
  build_assets() # 构建 assets

  apk_path = run_flutter_build_apk()

  # 🔥 上传到蒲公英
  if upload_to_pgyer
    pgyer_api_key = ENV['PGYER_API_KEY']
    pgyer(
      api_key: pgyer_api_key,
      apk: apk_path,
      user_download_file_name: apk_path.split('/').last,
    )
  end

  # 🔥 上传到 Hugging Face
  if upload_to_huggingface && !huggingface_repo_id.nil? && !huggingface_repo_id.empty?
    apk_filename = apk_path.split('/').last
    huggingface(
      repo_id: huggingface_repo_id,
      file_path: apk_path,
      path_in_repo: "android-arm64/#{apk_filename}",
      commit_message: "Upload #{version_number} (#{build_number}) - #{apk_filename}",
      repo_type: 'dataset',
    )
  end

  # 🔥 上传到 GitHub Release
  upload_to_github = params[:upload_to_github] == false ? false : true
  if upload_to_github
    # Get full version from pubspec.yaml (read from project root)
    require 'yaml'
    project_root = File.expand_path('..', __dir__)
    pubspec_path = File.join(project_root, 'pubspec.yaml')
    pubspec = YAML.load_file(pubspec_path)
    full_version = pubspec['version'] # e.g., "3.4.0+609"

    github_release(
      repo: 'RWKV-APP/RWKV_APP',
      version: full_version,
      file_path: apk_path,
      branch: 'dev',
      release_name: full_version,
      release_notes: "Release #{full_version}\n\nVersion: #{version_number}\nBuild: #{build_number}",
    )
  end

  # 🔥 构建并上传 macOS DMG
  macos_build_and_upload(
    upload_to_github: true,
    upload_to_huggingface: true,
    huggingface_repo_id: huggingface_repo_id,
  )

  # 🔥 上传到 TestFlight
  if upload_to_testflight
    ios_upload(groups: ['External'])
  end

  if env == 'chat' && !skip_git_reset
    git_reset()
  end
end

lane :ios_upload do |params|
  run_flutter_build_ipa()
  build_app(
    project: './ios/Runner.xcodeproj',
    skip_build_archive: true,
    archive_path: './build/ios/archive/Runner.xcarchive',
  )
  upload_to_testflight(
    skip_submission: true,
    distribute_external: params[:groups].include?('External'),
    changelog: 'Bug fixes and UI improvements',
    groups: params[:groups],
    localized_build_info: {
      "default": {
        whats_new: 'Bug fixes and UI improvements',
      },
      "zh-Hans": {
        whats_new: '修复已知问题，提升用户体验',
      },
    },
  )
end

lane :ios_upload_to_testflight do |params|
  upload_to_testflight(
    skip_submission: true,
    distribute_external: true,
    changelog: 'Bug fixes and UI improvements',
    groups: ['External'],
    localized_build_info: {
      "default": {
        whats_new: 'Bug fixes and UI improvements',
      },
      "zh-Hans": {
        whats_new: '修复已知问题，提升用户体验',
      },
    },
  )
end

lane :global_replace do |params|
  raw_switch_android_files(env: params[:env])
  global_config_replace(env: params[:env])
end

lane :switch_env do |params|
  raw_switch_android_files(env: params[:env])
  global_replace(env: params[:env])
  build_assets()
end

lane :test do |params|
  ios_upload(groups: ['External'])
end

lane :test_huggingface_upload do |params|
  # 获取 Hugging Face 配置
  repo_id = params[:repo_id] || ENV['HF_DATASETS_ID']
  repo_type = params[:repo_type] || 'dataset'
  path_in_repo = params[:path_in_repo] || 'test/empty_file.txt'

  if repo_id.nil? || repo_id.empty?
    UI.user_error!("You must provide :repo_id parameter or set HF_DATASETS_ID environment variable (e.g., 'HaloWang/rwkv-chat')")
  end

  # 创建临时空文件
  test_file_path = File.join(Dir.tmpdir, "huggingface_test_empty_#{Time.now.to_i}.txt")
  File.write(test_file_path, '')

  UI.message('🧪 Testing Hugging Face upload with empty file')
  UI.message("Repository: #{repo_id}")
  UI.message("File path: #{test_file_path}")
  UI.message("Path in repo: #{path_in_repo}")

  begin
    # 上传空文件到 Hugging Face
    huggingface(
      repo_id: repo_id,
      file_path: test_file_path,
      path_in_repo: path_in_repo,
      commit_message: params[:commit_message] || "Test upload empty file - #{Time.now.strftime('%Y-%m-%d %H:%M:%S')}",
      repo_type: repo_type,
    )

    UI.success('✅ Successfully uploaded empty file to Hugging Face!')
    UI.success("Repository: https://huggingface.co/datasets/#{repo_id}") if repo_type == 'dataset'
    UI.success("Repository: https://huggingface.co/#{repo_id}") if repo_type == 'model'
    UI.success("File: https://huggingface.co/datasets/#{repo_id}/resolve/main/#{path_in_repo}") if repo_type == 'dataset'
    UI.success("File: https://huggingface.co/#{repo_id}/resolve/main/#{path_in_repo}") if repo_type == 'model'
  rescue => e
    UI.user_error!("❌ Failed to upload empty file to Hugging Face: #{e.message}")
  ensure
    # 清理临时文件
    if File.exist?(test_file_path)
      File.delete(test_file_path)
      UI.message('🧹 Cleaned up temporary test file')
    end
  end
end

lane :lint do |params|
  raw_change_analysis_options()
  dart_fix()
  raw_change_analysis_options()
end

lane :bump_version_and_build_number do |params|
  version_number = raw_increase_build_number()
  version_number = raw_increase_version_number()
end

# ✅ Shared

lane :dart_fix do
  sh 'cd ..;dart fix --apply;cd fastlane'
end

lane :git_reset do
  sh "cd ..;git add .;git add .;git reset --hard;cd #{Dir.pwd}"
end

lane :build_assets do
  sh 'cd ..;dart run tools/bin/tools.dart;cd fastlane'
  sh 'cd ..;dart run flutter_native_splash:create --path=flutter_native_splash.yaml;cd fastlane'
  sh 'cd ..;dart run icons_launcher:create;cd fastlane'
end

lane :android_play_store do
  run_flutter_build_aab()
  upload_to_play_store(
    aab: './build/app/outputs/bundle/release/app-release.aab',
    track: 'internal',
    skip_upload_apk: true,
    skip_upload_metadata: true,
    skip_upload_changelogs: true,
    skip_upload_images: true,
    skip_upload_screenshots: true,
  )
end

lane :upload_to_huggingface do |params|
  repo_id = params[:repo_id] || ENV['HF_DATASETS_ID']
  file_path = params[:file_path]

  if repo_id.nil? || repo_id.empty?
    UI.user_error!("You must provide :repo_id parameter or set HF_DATASETS_ID environment variable (e.g., 'HaloWang/rwkv-chat')")
  end

  if file_path.nil? || !File.exist?(file_path)
    UI.user_error!("File not found: #{file_path}")
  end

  huggingface(
    repo_id: repo_id,
    file_path: file_path,
    path_in_repo: params[:path_in_repo] || File.basename(file_path),
    commit_message: params[:commit_message] || "Upload #{File.basename(file_path)}",
    repo_type: params[:repo_type] || 'dataset',
  )
end

lane :macos_build_and_upload do |params|
  upload_to_github = params[:upload_to_github] == false ? false : true
  upload_to_huggingface = params[:upload_to_huggingface] == false ? false : true
  huggingface_repo_id = params[:huggingface_repo_id] || ENV['HF_DATASETS_ID']

  # Get version info
  require 'yaml'
  project_root = File.expand_path('..', __dir__)
  pubspec_path = File.join(project_root, 'pubspec.yaml')
  pubspec = YAML.load_file(pubspec_path)
  full_version = pubspec['version'] # e.g., "3.4.0+609"
  version_parts = full_version.split('+')
  version_number = version_parts[0]
  build_number = version_parts[1] || '1'

  # Build macOS DMG
  dmg_path = run_flutter_build_macos_dmg(
    certificate_path: ENV['MACOS_CERTIFICATE_PATH'],
    certificate_base64: ENV['MACOS_CERTIFICATE'],
    certificate_password: ENV['MACOS_CERTIFICATE_PWD'],
    identity_id: ENV['MACOS_IDENTITY_ID'],
  )

  dmg_filename = File.basename(dmg_path)

  # 🔥 上传到 GitHub Release
  if upload_to_github
    github_release(
      repo: 'RWKV-APP/RWKV_APP',
      version: full_version,
      file_path: dmg_path,
      branch: 'dev',
      release_name: full_version,
      release_notes: "Release #{full_version}\n\nVersion: #{version_number}\nBuild: #{build_number}",
    )
  end

  # 🔥 上传到 Hugging Face
  if upload_to_huggingface && !huggingface_repo_id.nil? && !huggingface_repo_id.empty?
    huggingface(
      repo_id: huggingface_repo_id,
      file_path: dmg_path,
      path_in_repo: "macos-universal/#{dmg_filename}",
      commit_message: "Upload #{version_number} (#{build_number}) - #{dmg_filename}",
      repo_type: 'dataset',
    )
  end
end
