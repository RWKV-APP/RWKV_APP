lane :all do |params|
  env = (params[:env] != 'chat' && params[:env] != nil && params[:env] != '') ? params[:env] : 'chat'
  increase_version = params[:increase_version] == false ? false : true
  upload_to_testflight = params[:upload_to_testflight] == false ? false : true
  upload_to_pgyer = params[:upload_to_pgyer] == false ? false : true
  skip_git_reset = params[:skip_git_reset] == true ? true : false

  build_number = raw_increase_build_number()
  raw_change_analysis_options()
  dart_fix()
  raw_change_analysis_options()
  version_number = raw_get_version_number()
  if increase_version
    version_number = raw_increase_version_number()
  end
  if env == 'chat'
    git_commit(message: version_number.to_s + '(' + build_number.to_s + ')', path: '*')
    # Push changes to remote repository
    push_to_git_remote()
  end
  global_replace(env: env) # 替换环境变量
  build_assets() # 构建 assets

  apk_path = run_flutter_build_apk()

  # 🔥 上传到蒲公英
  if upload_to_pgyer
    pgyer_api_key = ENV['PGYER_API_KEY']
    pgyer(
      api_key: pgyer_api_key,
      apk: apk_path,
      user_download_file_name: apk_path.split('/').last,
    )
  end

  # 🔥 上传到 GitHub Release
  # Use github_release action for consistent release management
  upload_to_github = params[:upload_to_github] == false ? false : true
  if upload_to_github
    # Get full version from pubspec.yaml (read from project root)
    require 'yaml'
    project_root = File.expand_path('..', __dir__)
    pubspec_path = File.join(project_root, 'pubspec.yaml')
    pubspec = YAML.load_file(pubspec_path)
    full_version = pubspec['version'] # e.g., "3.4.0+609"
    # Extract semantic version for release name (tag name is also semantic version)
    semantic_version = full_version.split('+')[0] # e.g., "3.4.0"

    github_release(
      repo: 'RWKV-APP/RWKV_APP',
      version: full_version,
      file_path: apk_path,
      branch: 'dev',
      release_name: semantic_version,
      release_notes: "Release #{full_version}\n\nVersion: #{version_number}\nBuild: #{build_number}",
    )

    # 🔥 上传到 Hugging Face (android-arm64)
    if ENV['HF_TOKEN'] && !ENV['HF_TOKEN'].empty?
      absolute_apk_path = File.expand_path(apk_path, project_root)
      apk_filename = File.basename(apk_path)
      UI.header '上传 APK 到 Hugging Face'
      huggingface(
        repo_id: ENV['HF_DATASETS_ID'] || 'rwkv-app/RWKV-Chat',
        file_path: absolute_apk_path,
        path_in_repo: "android-arm64/#{apk_filename}",
        commit_message: "Upload APK #{apk_filename} (v#{full_version})",
        repo_type: 'dataset',
      )
      UI.success '✅ APK 已上传到 Hugging Face'
    else
      UI.important '跳过 Hugging Face 上传 (HF_TOKEN 未设置)'
    end
  end

  # 🔥 构建并上传 macOS DMG
  macos_build_and_upload(
    upload_to_github: true,
  )

  # 🔥 上传到 TestFlight
  if upload_to_testflight
    ios_upload(groups: ['External'])
  end

  if env == 'chat' && !skip_git_reset
    git_reset()
  end
end

lane :ios_upload do |params|
  run_flutter_build_ipa()
  build_app(
    project: './ios/Runner.xcodeproj',
    skip_build_archive: true,
    archive_path: './build/ios/archive/Runner.xcarchive',
  )
  upload_to_testflight(
    skip_submission: true,
    distribute_external: params[:groups].include?('External'),
    changelog: 'Bug fixes and UI improvements',
    groups: params[:groups],
    localized_build_info: {
      "default": {
        whats_new: 'Bug fixes and UI improvements',
      },
      "zh-Hans": {
        whats_new: '修复已知问题，提升用户体验',
      },
    },
  )
end

lane :ios_upload_to_testflight do |params|
  upload_to_testflight(
    skip_submission: true,
    distribute_external: true,
    changelog: 'Bug fixes and UI improvements',
    groups: ['External'],
    localized_build_info: {
      "default": {
        whats_new: 'Bug fixes and UI improvements',
      },
      "zh-Hans": {
        whats_new: '修复已知问题，提升用户体验',
      },
    },
  )
end

lane :global_replace do |params|
  raw_switch_android_files(env: params[:env])
  global_config_replace(env: params[:env])
end

lane :switch_env do |params|
  raw_switch_android_files(env: params[:env])
  global_replace(env: params[:env])
  build_assets()
end

lane :test do |params|
  ios_upload(groups: ['External'])
end

lane :lint do |params|
  raw_change_analysis_options()
  dart_fix()
  raw_change_analysis_options()
end

lane :bump_version_and_build_number do |params|
  version_number = raw_increase_build_number()
  version_number = raw_increase_version_number()
end

# ✅ Shared

lane :dart_fix do
  sh 'cd ..;dart fix --apply;cd fastlane'
end

lane :git_reset do
  sh "cd ..;git add .;git add .;git reset --hard;cd #{Dir.pwd}"
end

lane :build_assets do
  sh 'cd ..;dart run tools/bin/tools.dart;cd fastlane'
  sh 'cd ..;dart run flutter_native_splash:create --path=flutter_native_splash.yaml;cd fastlane'
  sh 'cd ..;dart run icons_launcher:create;cd fastlane'
end

lane :android_play_store do
  run_flutter_build_aab()
  upload_to_play_store(
    aab: './build/app/outputs/bundle/release/app-release.aab',
    track: 'internal',
    skip_upload_apk: true,
    skip_upload_metadata: true,
    skip_upload_changelogs: true,
    skip_upload_images: true,
    skip_upload_screenshots: true,
  )
end

lane :macos_build_and_upload do |params|
  upload_to_github = params[:upload_to_github] == false ? false : true
  upload_to_huggingface = params[:upload_to_huggingface] == false ? false : true

  # 1. 基础信息准备
  require 'yaml'
  require 'shellwords'
  project_root = File.expand_path('..', __dir__)
  pubspec_path = File.join(project_root, 'pubspec.yaml')
  pubspec = YAML.load_file(pubspec_path)
  full_version = pubspec['version']
  version_parts = full_version.split('+')
  version_number = version_parts[0]
  build_number = version_parts[1] || '1'

  # 请确保此 Bundle ID 与 Apple Developer 后台一致
  bundle_id = 'com.rwkv.chat.v7.100m'

  p12_path = ENV['MACOS_CERTIFICATE_PATH']
  p12_pwd = ENV['MACOS_CERTIFICATE_PWD']
  identity_id = ENV['MACOS_TEAM_ID']

  # 2. Keychain 配置
  keychain_name = 'build_temp_keychain'
  keychain_pwd = 'temp_password_123'
  # 关键修复：使用 -db 后缀，这是 macOS 的标准物理文件名后缀
  keychain_db_path = File.expand_path("~/Library/Keychains/#{keychain_name}-db")
  signing_identity = nil

  if p12_path && File.exist?(p12_path)
    # 彻底清理旧的
    # 只有当文件确实存在时才尝试删除
    if File.exist?(keychain_db_path)
      delete_keychain(name: keychain_name)
    end

    # 创建 Keychain
    create_keychain(
      name: keychain_name,
      password: keychain_pwd,
      default_keychain: false,
      unlock: true,
      timeout: 3600,
    )

    # 导入证书
    import_certificate(
      keychain_name: keychain_name,
      keychain_password: keychain_pwd,
      certificate_path: p12_path,
      certificate_password: p12_pwd,
    )

    # 关键步骤：使用 Fastlane 原生 action 解锁并将其加入搜索列表 (add_to_search_list)
    # 这一步是后续 security 命令能"看到"该钥匙串的前提
    unlock_keychain(
      path: keychain_name,
      password: keychain_pwd,
      add_to_search_list: true,
    )

    # 核心修复：手动设置 Partition List，防止签名时弹出密码输入框
    # 注意这里使用的是上面定义的带 -db 的绝对路径
    sh("security set-key-partition-list -S apple-tool:,apple:,codesign: -s -k #{Shellwords.escape(keychain_pwd)} #{keychain_db_path}")

    # 获取签名标识
    identity_output = `security find-identity -v -p codesigning #{keychain_db_path} | grep -o '"[^"]*"' | head -1 | tr -d '"'`.strip
    signing_identity = identity_output
    UI.message("Using signing identity: #{signing_identity}")
  end

  begin
    # 3. 编译 DMG (确保已开启 Hardened Runtime 以通过公证)
    dmg_path = run_flutter_build_macos_dmg(
      identity_id: signing_identity,
      keychain_name: signing_identity ? keychain_db_path : nil,
    )

    # 核心修复：确保 dmg_path 是绝对路径
    # 使用之前定义的 project_root 来锚定路径
    absolute_dmg_path = File.expand_path(dmg_path, project_root)
    UI.message("准备公证文件，绝对路径为: #{absolute_dmg_path}")

    # 4. 🔥 公证 (Notarization)
    UI.header '开始公证 (Notarizing)...'

    # 使用绝对路径调用 notarytool
    sh("xcrun notarytool submit #{Shellwords.escape(absolute_dmg_path)} " \
    "--apple-id #{Shellwords.escape(ENV['APPLE_ID_EMAIL'])} " \
    "--password #{Shellwords.escape(ENV['MACOS_APP_PASSWORD'])} " \
    "--team-id #{Shellwords.escape(ENV['MACOS_TEAM_ID'])} " \
    '--wait')

    # 5. 🔥 钉住证书 (Stapler)
    UI.message '公证成功，正在执行 Staple...'
    sh("xcrun stapler staple #{Shellwords.escape(absolute_dmg_path)}")

    UI.success '✅ macOS 应用公证并缝合完成！'
  ensure
    # 无论结果如何，清理临时钥匙串
    if p12_path && File.exist?(p12_path)
      delete_keychain(name: keychain_name)
    end
  end

  if upload_to_github
    github_release(
      repo: 'RWKV-APP/RWKV_APP',
      version: full_version,
      file_path: dmg_path,
      branch: 'dev',
      release_name: version_number,
      release_notes: "Release #{full_version}\n\nVersion: #{version_number}\nBuild: #{build_number}",
    )
  end

  if upload_to_huggingface && ENV['HF_TOKEN'] && !ENV['HF_TOKEN'].empty?
    dmg_filename = File.basename(dmg_path)
    UI.header '上传 DMG 到 Hugging Face'
    huggingface(
      repo_id: ENV['HF_DATASETS_ID'] || 'rwkv-app/RWKV-Chat',
      file_path: absolute_dmg_path,
      path_in_repo: "macos-universal/#{dmg_filename}",
      commit_message: "Upload DMG #{dmg_filename} (v#{full_version})",
      repo_type: 'dataset',
    )
    UI.success '✅ DMG 已上传到 Hugging Face'
  else
    UI.important '跳过 Hugging Face 上传 (HF_TOKEN 未设置)'
  end
end

# 测试上传到 Hugging Face
lane :test_huggingface do |params|
  # 从参数或环境变量获取配置
  repo_id = params[:repo_id] || ENV['HF_DATASETS_ID'] || 'rwkv-app/RWKV-Chat'
  file_path = params[:file_path] || ENV['HF_FILE_PATH']
  path_in_repo = params[:path_in_repo] || ENV['HF_PATH_IN_REPO']
  commit_message = params[:commit_message] || ENV['HF_COMMIT_MESSAGE'] || 'Test upload via fastlane'
  repo_type = params[:repo_type] || ENV['HF_REPO_TYPE'] || 'dataset'

  # 如果没有提供文件路径，创建一个测试文件
  if file_path.nil? || file_path.empty?
    require 'fileutils'
    test_file_path = File.join(Dir.tmpdir, "fastlane_test_#{Time.now.to_i}.txt")
    test_content = <<~CONTENT
      Fastlane Hugging Face Upload Test
      Created at: #{Time.now}
      This is a test file for verifying the Hugging Face upload functionality.
    CONTENT
    File.write(test_file_path, test_content)
    file_path = test_file_path
    UI.message("创建测试文件: #{file_path}")
  end

  UI.header '准备上传到 Hugging Face'
  UI.message("Repository: #{repo_id}")
  UI.message("File: #{file_path}")
  UI.message("Path in repo: #{path_in_repo || File.basename(file_path)}")
  UI.message("Repo type: #{repo_type}")

  # 调用 huggingface action
  huggingface(
    repo_id: repo_id,
    file_path: file_path,
    path_in_repo: path_in_repo,
    commit_message: commit_message,
    repo_type: repo_type,
  )

  UI.success '✅ 上传完成！'
end

# -----------------------------------------------------------------------
#  🚑 紧急恢复专用 Lane
#  用于 all lane 构建成功但在上传阶段失败时，从上传 APK 开始继续执行
# -----------------------------------------------------------------------
lane :resume_upload do |params|
  # 1. 读取当前 pubspec.yaml 中的版本号 (因为之前的 all lane 已经修改并提交了)
  require 'yaml'
  project_root = File.expand_path('..', __dir__)
  pubspec_path = File.join(project_root, 'pubspec.yaml')
  pubspec = YAML.load_file(pubspec_path)

  full_version = pubspec['version'] # e.g., "3.4.3+629"
  version_parts = full_version.split('+')
  semantic_version = version_parts[0] # "3.4.3"
  build_number = version_parts[1]     # "629"

  UI.message "🔄 恢复上传流程: 版本 #{full_version}"

  # 2. 尝试定位之前构建好的 APK 文件
  # 根据你的日志，文件名格式似乎是 rwkv_chat_版本_构建号.apk
  apk_name = "rwkv_chat_#{semantic_version}_#{build_number}.apk"
  apk_path = File.join(project_root, "build/app/outputs/flutter-apk/#{apk_name}")

  # 如果找不到带版本号的，尝试找默认的 app-release.apk
  unless File.exist?(apk_path)
    UI.important "未找到 #{apk_name}，尝试查找 app-release.apk..."
    apk_path = File.join(project_root, 'build/app/outputs/flutter-apk/app-release.apk')
  end

  if File.exist?(apk_path)
    UI.success "✅ 找到 APK 文件: #{apk_path}"

    # 3. 🔥 重试上传到 GitHub Release (Android)
    # 注意：如果 Release 已存在但为空，github_release 可能会报错，这里假设它能处理或只是上传资源
    # 如果 github_release 报错说 tag 已存在，你可能需要手动在网页上传一次 APK，或者暂时注释掉这块
    begin
      github_release(
        repo: 'RWKV-APP/RWKV_APP',
        version: full_version,
        file_path: apk_path,
        branch: 'dev',
        release_name: semantic_version,
        release_notes: "Release #{full_version}\n\nVersion: #{semantic_version}\nBuild: #{build_number}",
      )
    rescue => e
      UI.error "GitHub Release 上传遇到问题 (可能是 Release 已存在): #{e.message}"
      UI.important '请尝试手动上传 APK，脚本将继续执行后续步骤...'
    end

    # 4. 🔥 恢复上传到 Hugging Face (Android)
    if ENV['HF_TOKEN'] && !ENV['HF_TOKEN'].empty?
      apk_filename = File.basename(apk_path)
      huggingface(
        repo_id: ENV['HF_DATASETS_ID'] || 'rwkv-app/RWKV-Chat',
        file_path: apk_path,
        path_in_repo: "android-arm64/#{apk_filename}",
        commit_message: "Upload APK #{apk_filename} (v#{full_version})",
        repo_type: 'dataset',
      )
    end
  else
    UI.user_error! '❌ 无法找到构建好的 APK 文件，无法恢复 Android 上传。'
  end

  # 5. 🔥 继续 macOS 流程 (macOS lane 内部会自己构建，所以是安全的)
  macos_build_and_upload(
    upload_to_github: true,
  )

  # 6. 🔥 继续 iOS 流程 (iOS lane 内部会自己构建，所以是安全的)
  upload_to_testflight_flag = params[:upload_to_testflight] == false ? false : true
  if upload_to_testflight_flag
    ios_upload(groups: ['External'])
  end

  # 7. Git Reset (清理)
  skip_git_reset = params[:skip_git_reset] == true ? true : false
  if !skip_git_reset
    git_reset()
  end

  UI.success '🎉 恢复流程执行完毕！'
end

# 测试 macOS DMG 构建流程（不签名）
lane :test_macos_dmg do |params|
  UI.header '测试 macOS DMG 构建流程'
  dmg_path = run_flutter_build_macos_dmg(
    identity_id: params[:identity_id], # 可选：如果提供则进行签名测试
    keychain_name: params[:keychain_name], # 可选
  )
  UI.success "✅ DMG 构建完成: #{dmg_path}"
end
