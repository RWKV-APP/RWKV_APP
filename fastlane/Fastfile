    skip_submission: true,
    distribute_external: true,
    changelog: 'Bug fixes and UI improvements',
    groups: ['External'],
    localized_build_info: {
      "default": {
        whats_new: 'Bug fixes and UI improvements',
      },
      "zh-Hans": {
        whats_new: '修复已知问题，提升用户体验',
      },
    },
  )
end

lane :global_replace do |params|
  raw_switch_android_files(env: params[:env])
  global_config_replace(env: params[:env])
end

lane :switch_env do |params|
  raw_switch_android_files(env: params[:env])
  global_replace(env: params[:env])
  build_assets()
end

lane :test do |params|
  ios_upload(groups: ['External'])
end

lane :test_huggingface_upload do |params|
  # 获取 Hugging Face 配置
  repo_id = params[:repo_id] || ENV['HF_REPO_ID'] || ENV['HF_DATABASE_ID']
  repo_type = params[:repo_type] || 'dataset'
  path_in_repo = params[:path_in_repo] || 'test/empty_file.txt'

  if repo_id.nil? || repo_id.empty?
    UI.user_error!("You must provide :repo_id parameter or set HF_REPO_ID/HF_DATABASE_ID environment variable (e.g., 'HaloWang/rwkv-chat')")
  end

  # 创建临时空文件
  test_file_path = File.join(Dir.tmpdir, "huggingface_test_empty_#{Time.now.to_i}.txt")
  File.write(test_file_path, '')

  UI.message('🧪 Testing Hugging Face upload with empty file')
  UI.message("Repository: #{repo_id}")
  UI.message("File path: #{test_file_path}")
  UI.message("Path in repo: #{path_in_repo}")

  begin
    # 上传空文件到 Hugging Face
    huggingface(
      repo_id: repo_id,
      file_path: test_file_path,
      path_in_repo: path_in_repo,
      commit_message: params[:commit_message] || "Test upload empty file - #{Time.now.strftime('%Y-%m-%d %H:%M:%S')}",
      repo_type: repo_type,
    )

    UI.success('✅ Successfully uploaded empty file to Hugging Face!')
    UI.success("Repository: https://huggingface.co/datasets/#{repo_id}") if repo_type == 'dataset'
    UI.success("Repository: https://huggingface.co/#{repo_id}") if repo_type == 'model'
    UI.success("File: https://huggingface.co/datasets/#{repo_id}/resolve/main/#{path_in_repo}") if repo_type == 'dataset'
    UI.success("File: https://huggingface.co/#{repo_id}/resolve/main/#{path_in_repo}") if repo_type == 'model'
  rescue => e
    UI.user_error!("❌ Failed to upload empty file to Hugging Face: #{e.message}")
  ensure
    # 清理临时文件
    if File.exist?(test_file_path)
      File.delete(test_file_path)
      UI.message('🧹 Cleaned up temporary test file')
    end
  end
end

lane :lint do |params|
  raw_change_analysis_options()
  dart_fix()
  raw_change_analysis_options()
end

lane :bump_version_and_build_number do |params|
  version_number = raw_increase_build_number()
  version_number = raw_increase_version_number()
end

# ✅ Shared

lane :upload_to_github_release do |params|
  repo = params[:repo] || 'RWKV-APP/RWKV_APP'
  full_version = params[:version]
  file_path = params[:file_path]
  branch = params[:branch] || 'dev'
  release_name = params[:release_name] || full_version
  release_notes = params[:release_notes] || "Release #{full_version}"

  if repo.nil? || repo.empty?
    UI.user_error!("You have to provide a repo (e.g., 'RWKV-APP/RWKV_APP')")
  end

  if full_version.nil? || full_version.empty?
    UI.user_error!('You have to provide a version')
  end

  # Extract semantic version (e.g., "3.4.0" from "3.4.0+612")
  # Tag name should only be the semantic version, not including build number
  version_parts = full_version.split('+')
  version = version_parts[0] # e.g., "3.4.0"

  if file_path.nil? || !File.exist?(file_path)
    UI.user_error!("File not found at path: #{file_path}")
  end

  # Convert to absolute path
  file_path = File.expand_path(file_path)

  # Check if gh CLI is installed
  unless system('which gh > /dev/null 2>&1')
    UI.user_error!('GitHub CLI (gh) is not installed. Please install it first: https://cli.github.com/')
  end

  # Check if user is authenticated
  auth_status = `gh auth status 2>&1`
  unless $?.success?
    UI.user_error!('You are not authenticated with GitHub CLI. Please run: gh auth login')
  end

  UI.message("Checking for existing release: #{version} (tag) in #{repo}")

  # Check if release exists (using semantic version as tag name)
  release_check = `gh release view #{version} --repo #{repo} 2>&1`
  release_exists = $?.success?

  if release_exists
    UI.message("Release #{version} already exists. Uploading file to existing release...")
    # Upload file to existing release (--clobber will overwrite if file exists)
    sh("gh release upload #{version} '#{file_path}' --repo #{repo} --clobber")
    UI.success("Successfully uploaded #{File.basename(file_path)} to release #{version}")
  else
    UI.message("Release #{version} does not exist. Creating new release...")

    # Get the latest commit from the branch
    branch_ref = `gh api repos/#{repo}/git/refs/heads/#{branch} 2>&1`
    unless $?.success?
      UI.user_error!("Failed to get branch #{branch} from repository #{repo}")
    end

    commit_sha = branch_ref.match(/"sha":"([^"]+)"/)
    if commit_sha.nil?
      UI.user_error!("Failed to get commit SHA from branch #{branch}")
    end
    commit_sha = commit_sha[1]

    UI.message("Creating release #{version} (tag) from branch #{branch} (commit: #{commit_sha[0..7]})...")

    # Check if tag exists (using semantic version as tag name)
    tag_check = `gh api repos/#{repo}/git/refs/tags/#{version} 2>&1`
    tag_exists = $?.success?

    # Create temporary file for release notes to handle multi-line text safely
    notes_file = File.join(Dir.tmpdir, "github_release_notes_#{Time.now.to_i}.txt")
    File.write(notes_file, release_notes)

    begin
      if tag_exists
        UI.message("Tag #{version} already exists. Using existing tag...")
        # Get the commit SHA that the tag points to
        tag_ref = `gh api repos/#{repo}/git/refs/tags/#{version} 2>&1`
        unless $?.success?
          UI.user_error!("Failed to get tag #{version} from repository #{repo}")
        end
        tag_commit_sha = tag_ref.match(/"sha":"([^"]+)"/)
        if tag_commit_sha.nil?
          UI.user_error!("Failed to get commit SHA from tag #{version}")
        end
        tag_commit_sha = tag_commit_sha[1]
        # Create release from existing tag using the commit SHA
        # Use semantic version as tag name, but full version in release name
        sh("gh release create #{version} --repo #{repo} --title '#{release_name}' --notes-file '#{notes_file}' --target #{tag_commit_sha} '#{file_path}'")
      else
        UI.message("Creating tag #{version} on branch #{branch}...")
        # Create tag first (using semantic version as tag name)
        sh("gh api repos/#{repo}/git/refs -X POST -f ref=refs/tags/#{version} -f sha=#{commit_sha}")
        # Create release from the new tag using the commit SHA and upload file in one command
        # Use semantic version as tag name, but full version in release name
        sh("gh release create #{version} --repo #{repo} --title '#{release_name}' --notes-file '#{notes_file}' --target #{commit_sha} '#{file_path}'")
      end
    ensure
      # Clean up temporary notes file
      if File.exist?(notes_file)
        File.delete(notes_file)
      end
    end

    UI.success("Successfully created release #{version} and uploaded #{File.basename(file_path)}")
  end

  UI.success("Release URL: https://github.com/#{repo}/releases/tag/#{version}")
end

lane :dart_fix do
  sh 'cd ..;dart fix --apply;cd fastlane'
end

lane :git_reset do
  sh "cd ..;git add .;git add .;git reset --hard;cd #{Dir.pwd}"
end

lane :build_assets do
  sh 'cd ..;dart run tools/bin/tools.dart;cd fastlane'
  sh 'cd ..;dart run flutter_native_splash:create --path=flutter_native_splash.yaml;cd fastlane'
  sh 'cd ..;dart run icons_launcher:create;cd fastlane'
end

lane :android_play_store do
  run_flutter_build_aab()
  upload_to_play_store(
    aab: './build/app/outputs/bundle/release/app-release.aab',
    track: 'internal',
    skip_upload_apk: true,
    skip_upload_metadata: true,
    skip_upload_changelogs: true,
    skip_upload_images: true,
    skip_upload_screenshots: true,
  )
end

lane :upload_to_huggingface do |params|
  repo_id = params[:repo_id] || ENV['HF_REPO_ID'] || ENV['HF_DATABASE_ID']
  file_path = params[:file_path]

  if repo_id.nil? || repo_id.empty?
    UI.user_error!("You must provide :repo_id parameter or set HF_REPO_ID/HF_DATABASE_ID environment variable (e.g., 'HaloWang/rwkv-chat')")
  end

  if file_path.nil? || !File.exist?(file_path)
    UI.user_error!("File not found: #{file_path}")
  end

  huggingface(
    repo_id: repo_id,
    file_path: file_path,
    path_in_repo: params[:path_in_repo] || File.basename(file_path),
    commit_message: params[:commit_message] || "Upload #{File.basename(file_path)}",
    repo_type: params[:repo_type] || 'dataset',
  )
end

lane :macos_build_and_upload do |params|
  upload_to_github = params[:upload_to_github] == false ? false : true
  upload_to_huggingface = params[:upload_to_huggingface] == false ? false : true
  huggingface_repo_id = params[:huggingface_repo_id] || ENV['HF_REPO_ID'] || ENV['HF_DATABASE_ID']

  # Get version info
  require 'yaml'
  project_root = File.expand_path('..', __dir__)
  pubspec_path = File.join(project_root, 'pubspec.yaml')
  pubspec = YAML.load_file(pubspec_path)
  full_version = pubspec['version'] # e.g., "3.4.0+609"
  version_parts = full_version.split('+')
  version_number = version_parts[0]
  build_number = version_parts[1] || '1'

  # Build macOS DMG
  dmg_path = run_flutter_build_macos_dmg(
    certificate_path: ENV['MACOS_CERTIFICATE_PATH'],
    certificate_base64: ENV['MACOS_CERTIFICATE'],
    certificate_password: ENV['MACOS_CERTIFICATE_PWD'],
    identity_id: ENV['MACOS_IDENTITY_ID'],
  )

  dmg_filename = File.basename(dmg_path)

  # 🔥 上传到 GitHub Release
  if upload_to_github
    upload_to_github_release(
      repo: 'RWKV-APP/RWKV_APP',
      version: full_version,
      file_path: dmg_path,
      branch: 'dev',
      release_name: full_version,
      release_notes: "Release #{full_version}\n\nVersion: #{version_number}\nBuild: #{build_number}",
    )
  end

  # 🔥 上传到 Hugging Face
  if upload_to_huggingface && !huggingface_repo_id.nil? && !huggingface_repo_id.empty?
    huggingface(
      repo_id: huggingface_repo_id,
      file_path: dmg_path,
      path_in_repo: "macos-universal/#{dmg_filename}",
      commit_message: "Upload #{version_number} (#{build_number}) - #{dmg_filename}",
      repo_type: 'dataset',
    )
  end
end
