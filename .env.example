# ============================================
# Remote Server Configuration
# ============================================
RWKV_REMOTE_HOST=your_remote_host
RWKV_REMOTE_PORT=22
RWKV_REMOTE_USER=your_username
RWKV_REMOTE_PASS=your_password_here
x-api-key=your_api_key_here

# ============================================
# Android Signing Configuration
# ============================================
# Android apk & aab
# Base64 encoded keystore file
ANDROID_KEYSTORE_BASE64=your_base64_encoded_keystore_here
ANDROID_KEYSTORE_PASSWORD=your_keystore_password
ANDROID_KEY_ALIAS=your_key_alias
ANDROID_KEY_PASSWORD=your_key_password

# ============================================
# iOS / macOS App Store Configuration
# ============================================
APPLE_ID_EMAIL=your_apple_id@example.com

# macOS DMG signing
# App-specific password for Apple ID
MACOS_APP_PASSWORD=your_app_specific_password
# Base64 encoded P12 certificate file
MACOS_CERTIFICATE=your_base64_encoded_certificate_here
MACOS_CERTIFICATE_PWD=your_certificate_password
# Team ID from Apple Developer account
MACOS_IDENTITY_ID=your_team_id

# ============================================
# HuggingFace Configuration
# ============================================
HF_TOKEN=your_huggingface_token
HF_DATASETS_ID=your_username/your-repo-name

# ============================================
# Pgyer (蒲公英) Configuration
# ============================================
PGYER_API_KEY=your_pgyer_api_key_here
