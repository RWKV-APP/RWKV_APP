        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"msg\" (\"id\" INTEGER NOT NULL, \"content\" TEXT NOT NULL, \"reference\" TEXT NULL, \"is_mine\" INTEGER NOT NULL CHECK (\"is_mine\" IN (0, 1)), \"type\" TEXT NOT NULL, \"is_reasoning\" INTEGER NOT NULL CHECK (\"is_reasoning\" IN (0, 1)), \"paused\" INTEGER NOT NULL CHECK (\"paused\" IN (0, 1)), \"image_url\" TEXT NULL, \"audio_url\" TEXT NULL, \"audio_length\" INTEGER NULL, \"is_sensitive\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_sensitive\" IN (0, 1)), \"tts_c_f_m_steps\" INTEGER NULL, \"tts_target\" TEXT NULL, \"tts_speaker_name\" TEXT NULL, \"tts_source_audio_path\" TEXT NULL, \"tts_instruction\" TEXT NULL, \"model_name\" TEXT NULL, \"running_mode\" TEXT NULL, \"build\" TEXT NOT NULL, \"raw_decode_params\" TEXT NULL, \"prefill_speed\" REAL NULL, \"decode_speed\" REAL NULL, PRIMARY KEY (\"id\"));"
